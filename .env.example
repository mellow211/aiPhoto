# Express 백엔드 포트 (기본값: 5000)
PORT=5000

# OpenAI API 키 (https://platform.openai.com 에서 발급 가능)
# 최우선으로 적용되어 GPT-4o (Vision) + DALL-E 3 파이프라인을 통해 캐리커처를 생성합니다.
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# Google Gemini API 키 (Google AI Studio에서 발급 가능)
# 2단계 캐리커처 생성 파이프라인(Gemini 2.5 Flash + Imagen 4) 활성화에 사용됩니다.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Stability AI API 키 (https://platform.stability.ai 에서 발급 가능)
# GEMINI_API_KEY가 없고 이 키만 있는 경우 활성화됩니다.
STABILITY_API_KEY=YOUR_STABILITY_API_KEY_HERE

# Replicate API 토큰 (https://replicate.com 에서 발급 가능)
# 최우선으로 적용되어 Replicate의 SDXL image-to-image API를 통해 캐리커처를 생성합니다.
REPLICATE_API_TOKEN=YOUR_REPLICATE_API_TOKEN_HERE

