{
  "version": 2,
  "cleanUrls": true,
  "functions": {
    "api/generate.js": {
      "maxDuration": 120
    }
  },
  "rewrites": [
    {
      "source": "/api/generate",
      "destination": "/api/generate.js"
    },
    {
      "source": "/api/status",
      "destination": "/api/status.js"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
