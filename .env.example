# Express backend port (Defaults to 5000)
PORT=5000

# Google Gemini API Key (Get yours from Google AI Studio)
# Enables the 2-stage caricature generation (Gemini 1.5 Flash + Imagen 3)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Stability AI API Key (Get yours from https://platform.stability.ai)
# Used as a fallback if STABILITY_API_KEY is defined instead of GEMINI_API_KEY
STABILITY_API_KEY=YOUR_STABILITY_API_KEY_HERE
